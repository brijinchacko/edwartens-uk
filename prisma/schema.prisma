generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SALES_LEAD
  ADMISSION_COUNSELLOR
  TRAINER
  STUDENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  ENROLLED
  LOST
}

enum StudentStatus {
  ONBOARDING
  ACTIVE
  ON_HOLD
  POST_TRAINING
  CAREER_SUPPORT
  COMPLETED
  ALUMNI
  DROPPED
}

enum CourseType {
  PROFESSIONAL_MODULE
  AI_MODULE
}

enum BatchStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PlacementStatus {
  PREPARING
  INTERVIEW
  OFFERED
  CONFIRMED
  REJECTED
}

enum CertificateType {
  CPD
  EXPERIENCE
  ISO
  COMPLETION
}

enum SessionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
}

enum PaymentType {
  DEPOSIT
  FULL
}

enum DocumentStatus {
  UPLOADED
  VERIFIED
  REJECTED
}

enum JobPlatform {
  CV_LIBRARY
  LINKEDIN
  INDEED
  OTHER
}

enum QuestionCategory {
  PRE_COURSE
  THEORY
}

enum AssessmentType {
  PRE_COURSE
  THEORY
  PRACTICAL
}

enum JourneyEventType {
  LEAD_CREATED
  LEAD_ASSIGNED
  LEAD_CONTACTED
  DEPOSIT_PAID
  FULL_PAYMENT
  STUDENT_CREATED
  ONBOARDING_STARTED
  ONBOARDING_COMPLETED
  BATCH_ASSIGNED
  DOCUMENT_UPLOADED
  DOCUMENT_VERIFIED
  SOFTWARE_VERIFIED
  TRAINING_STARTED
  TRAINING_COMPLETED
  PROJECT_SUBMITTED
  ASSESSMENT_COMPLETED
  PRE_COURSE_COMPLETED
  THEORY_ASSESSMENT_COMPLETED
  PRACTICAL_SUBMITTED
  PRACTICAL_GRADED
  CERTIFICATE_DISPATCH_PENDING
  CERTIFICATE_SENT
  RESUME_REVIEW
  LINKEDIN_VERIFIED
  JOB_APPLICATION
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  CERTIFICATE_ISSUED
  STATUS_CHANGE
  NOTE_ADDED
  FEEDBACK_RECEIVED
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String
  phone           String?
  role            Role      @default(STUDENT)
  avatar          String?
  dateOfBirth     DateTime?
  address         String?
  emergencyName   String?
  emergencyPhone  String?
  isActive        Boolean   @default(true)
  onboarded       Boolean   @default(false)
  termsAccepted   Boolean   @default(false)
  termsAcceptedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student         Student?
  employeeProfile Employee?
  activityLogs    ActivityLog[]
  notifications   Notification[]
}

model Employee {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  department      String?
  specialization  String?
  bio             String?
  hireDate        DateTime  @default(now())

  assignedLeads   Lead[]
  batches         Batch[]
  sessions        Session[]
  assessments     Assessment[]
  counselledStudents Student[] @relation("CounsellorStudents")
  salesTargets     SalesTarget[]
  salesIncentives      SalesIncentive[]
  practicalSessions    PracticalSession[] @relation("PracticalTrainer")
  workSessions         EmployeeWorkSession[]
  whatsappTasks        WhatsAppTask[]

  // Microsoft Outlook integration (per-user OAuth)
  msAccessToken    String?
  msRefreshToken   String?
  msTokenExpiry    DateTime?
  msEmail          String?  // Their connected Outlook email
}

model EmployeeWorkSession {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  checkInAt       DateTime
  checkOutAt      DateTime?
  workLocation    String   @default("HOME") // HOME, OFFICE, REMOTE
  checkInNote     String?
  checkOutSummary String?
  totalMinutes    Int?
  activeMinutes   Int?
  idleMinutes     Int?
  breakMinutes    Int?
  status          String   @default("CHECKED_IN") // CHECKED_IN, ON_BREAK, IDLE, CHECKED_OUT

  activities      EmployeeActivity[]
  breaks          EmployeeBreak[]

  @@index([employeeId, date])
}

model EmployeeActivity {
  id            String   @id @default(cuid())
  sessionId     String
  session       EmployeeWorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type          String   // ACTIVE, IDLE, BREAK, AWAY
  startedAt     DateTime @default(now())
  endedAt       DateTime?
  durationMin   Int?
  description   String?
}

model EmployeeBreak {
  id          String   @id @default(cuid())
  sessionId   String
  session     EmployeeWorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  reason      String?
}

model Student {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollmentDate  DateTime      @default(now())
  batchId         String?
  batch           Batch?        @relation(fields: [batchId], references: [id])
  currentPhase    Int           @default(0)
  course          CourseType
  status          StudentStatus @default(ONBOARDING)
  counsellorId    String?
  counsellor      Employee?     @relation("CounsellorStudents", fields: [counsellorId], references: [id])
  qualification   String?
  passoutYear     Int?
  previousExp     String?
  paymentStatus   PaymentStatus @default(PENDING)
  paidAmount      Float?
  stripePaymentId String?

  assessments     Assessment[]
  placements      Placement[]
  certificates    Certificate[]
  sessionProgress SessionProgress[]
  documents       Document[]
  jobApplications JobApplication[]
  payments        Payment[]
  journeyEvents       StudentJourney[]
  assessmentAttempts   AssessmentAttempt[]
  projectSubmissions   ProjectSubmission[]
  resumeReviews        ResumeReview[]
  linkedInProfile      LinkedInProfile?
  jobApplicationLogs   JobApplicationLog[]
  weeklyJobShares      WeeklyJobShare[]
  interviewSupports    InterviewSupport[]
  softwareChecklist    SoftwareChecklist?
  batchAttendance      BatchAttendance[]
  batchReadiness       BatchReadiness[]
  invoices             Invoice[]
  feedback             StudentFeedback[]
  alumniProfile        AlumniProfile?
  referralsMade        Referral[]    @relation("ReferralsMade")
  signatures           DocumentSignature[]
  practicalBookings    PracticalBooking[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Lead {
  id              String     @id @default(cuid())
  name            String
  email           String     @default("")
  phone           String
  alternatePhone  String?
  qualification   String?
  courseInterest  CourseType?
  source          String     @default("website")
  status          LeadStatus @default(NEW)
  assignedToId    String?
  assignedTo      Employee?  @relation(fields: [assignedToId], references: [id])
  followUpDate    DateTime?
  enquiryDate     DateTime   @default(now())
  notes           LeadNote[]
  payments        Payment[]
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  convertedToStudentId String?
  leadScore      Int      @default(0)
  scoreBreakdown Json?
  lastScoredAt   DateTime?
  whatsappTasks  WhatsAppTask[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model EmailSequence {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  trigger     String   // NEW_LEAD, CONTACTED, QUALIFIED, POST_CONSULTATION, ENROLLED
  steps       EmailSequenceStep[]
  createdAt   DateTime @default(now())
}

model EmailSequenceStep {
  id           String        @id @default(cuid())
  sequenceId   String
  sequence     EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber   Int
  delayDays    Int
  templateId   String
  subject      String?
  isActive     Boolean       @default(true)

  @@unique([sequenceId, stepNumber])
}

model EmailSequenceLog {
  id          String   @id @default(cuid())
  leadId      String
  sequenceId  String
  stepNumber  Int
  sentAt      DateTime @default(now())
  status      String   @default("SENT")
  error       String?
}

model LeadNote {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content     String
  createdBy   String
  createdAt   DateTime @default(now())
}

model Batch {
  id                String      @id @default(cuid())
  name              String
  course            CourseType
  startDate         DateTime
  endDate           DateTime?
  capacity          Int         @default(6)
  status            BatchStatus @default(UPCOMING)
  instructorId      String?
  instructor        Employee?   @relation(fields: [instructorId], references: [id])
  location          String?     @default("Milton Keynes")
  isAutoGenerated   Boolean     @default(false)
  mode              String      @default("ONLINE") // ONLINE, OFFLINE, HYBRID
  teamsLink         String?
  trainerAccepted   Boolean     @default(false)
  trainerAcceptedAt DateTime?
  batchReady        Boolean     @default(false)
  trainerFeedback   String?

  students          Student[]
  sessions          Session[]
  payments          Payment[]
  batchDays         BatchDay[]
  readiness         BatchReadiness[]
  practicalSessions PracticalSession[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model BatchDay {
  id             String   @id @default(cuid())
  batchId        String
  batch          Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  dayNumber      Int
  date           DateTime
  status         String   @default("SCHEDULED")
  startedAt      DateTime?
  endedAt        DateTime?
  breakStartedAt DateTime?
  breakEndedAt   DateTime?
  teamsLink      String?
  topic          String?
  trainerNotes   String?
  startedBy      String?

  attendance     BatchAttendance[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([batchId, dayNumber])
}

model BatchAttendance {
  id         String   @id @default(cuid())
  batchDayId String
  batchDay   BatchDay @relation(fields: [batchDayId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  status     String   @default("ABSENT")
  joinedAt   DateTime?
  leftAt     DateTime?
  notes      String?

  @@unique([batchDayId, studentId])
}

model BatchReadiness {
  id                String   @id @default(cuid())
  batchId           String
  batch             Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id])
  feePaid           Boolean  @default(false)
  documentsUploaded Boolean  @default(false)
  softwareInstalled Boolean  @default(false)
  softwareVerified  Boolean  @default(false)
  prerequisitesDone Boolean  @default(false)
  isReady           Boolean  @default(false)
  verifiedBy        String?
  verifiedAt        DateTime?
  notes             String?

  @@unique([batchId, studentId])
}

model PracticalSession {
  id              String    @id @default(cuid())
  batchId         String
  batch           Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  title           String    @default("Practical Session - Milton Keynes")
  date            DateTime
  startTime       String?
  endTime         String?
  location        String    @default("8 Lyon Road, Milton Keynes, MK1 1EX")
  trainerId       String?
  trainer         Employee? @relation("PracticalTrainer", fields: [trainerId], references: [id])
  status          String    @default("SCHEDULED")
  notes           String?
  capacity        Int       @default(6)
  minCapacity     Int       @default(3)
  bookingDeadline DateTime?
  bookings        PracticalBooking[]
  createdAt       DateTime  @default(now())
}

model PracticalBooking {
  id                 String           @id @default(cuid())
  practicalSessionId String
  practicalSession   PracticalSession @relation(fields: [practicalSessionId], references: [id], onDelete: Cascade)
  studentId          String
  student            Student          @relation(fields: [studentId], references: [id])
  status             String           @default("INVITED") // INVITED, ACCEPTED, DECLINED, CANCELLED, ATTENDED
  invitedAt          DateTime         @default(now())
  respondedAt        DateTime?
  cancelledAt        DateTime?
  cancelReason       String?
  notes              String?

  @@unique([practicalSessionId, studentId])
}

model Phase {
  id              String    @id @default(cuid())
  number          Int
  name            String
  description     String
  course          CourseType
  durationDays    Int
  order           Int

  assessments     Assessment[]
  sessions        Session[]
  @@unique([number, course])
}

model Session {
  id              String    @id @default(cuid())
  title           String
  description     String?
  phaseId         String
  phase           Phase     @relation(fields: [phaseId], references: [id])
  batchId         String?
  batch           Batch?    @relation(fields: [batchId], references: [id])
  instructorId    String?
  instructor      Employee? @relation(fields: [instructorId], references: [id])
  videoUrl        String?
  videoPlatform   String?
  videoId         String?
  thumbnailUrl    String?
  duration        Int?
  isMandatory     Boolean   @default(true)
  order           Int
  materials       Json?

  progress        SessionProgress[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SessionProgress {
  id              String        @id @default(cuid())
  studentId       String
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionId       String
  session         Session       @relation(fields: [sessionId], references: [id])
  status          SessionStatus @default(NOT_STARTED)
  watchedSeconds  Int           @default(0)
  completedAt     DateTime?
  lastAccessedAt  DateTime?
  @@unique([studentId, sessionId])
}

model Assessment {
  id              String    @id @default(cuid())
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  phaseId         String
  phase           Phase     @relation(fields: [phaseId], references: [id])
  assessorId      String?
  assessor        Employee? @relation(fields: [assessorId], references: [id])
  score           Float?
  maxScore        Float     @default(100)
  passed          Boolean   @default(false)
  feedback        String?
  assessedAt      DateTime  @default(now())
}

model Placement {
  id              String          @id @default(cuid())
  studentId       String
  student         Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  company         String
  role            String
  salary          Float?
  location        String?
  status          PlacementStatus @default(PREPARING)
  interviewDate   DateTime?
  offerDate       DateTime?
  joinDate        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Certificate {
  id              String               @id @default(cuid())
  studentId       String
  student         Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type            CertificateType
  certificateNo   String               @unique
  issuedDate      DateTime             @default(now())
  expiryDate      DateTime?
  pdfUrl          String?
  qrCode          String?
  isValid         Boolean              @default(true)
  metadata        Json?
  dispatch        CertificateDispatch?
  @@index([certificateNo])
}

model CertificateDispatch {
  id            String      @id @default(cuid())
  certificateId String      @unique
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  status        String      @default("PENDING")
  assignedTo    String?
  sentAt        DateTime?
  trackingNo    String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  @@index([status])
}

model Document {
  id              String         @id @default(cuid())
  studentId       String
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name            String
  type            String
  fileUrl         String
  fileSize        Int?
  mimeType        String?
  status          DocumentStatus @default(UPLOADED)
  reviewedBy      String?
  reviewNote      String?
  uploadedAt      DateTime       @default(now())
}

model JobNotification {
  id              String   @id @default(cuid())
  company         String
  role            String
  location        String?
  salaryRange     String?
  description     String
  requirements    String?
  targetCourse    CourseType?
  targetBatchId   String?
  sentTo          String[]
  sentAt          DateTime @default(now())
  createdBy       String

  applications    JobApplication[]
}

model JobApplication {
  id              String          @id @default(cuid())
  jobId           String
  job             JobNotification @relation(fields: [jobId], references: [id])
  studentId       String
  student         Student         @relation(fields: [studentId], references: [id])
  status          String          @default("INTERESTED")
  appliedAt       DateTime        @default(now())
  @@unique([jobId, studentId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String
  type        String
  read        Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
  @@index([userId, createdAt])
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  date          DateTime      @default(now())
  dueDate       DateTime?
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  paymentId     String?
  description   String
  lineItems     Json
  subtotal      Int           // in pence
  vatRate       Float         @default(20)
  vatAmount     Int           // in pence
  total         Int           // in pence
  status        InvoiceStatus @default(ISSUED)
  pdfUrl        String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  @@index([invoiceNumber])
  @@index([studentId])
}

model Payment {
  id                    String      @id @default(cuid())
  stripeSessionId       String      @unique
  stripePaymentIntentId String?
  amount                Int         // amount in pence
  currency              String      @default("gbp")
  type                  PaymentType
  status                String      @default("pending") // pending, completed, failed
  customerEmail         String
  customerName          String
  phone                 String?
  courseInterest        CourseType
  batchId               String?
  batch                 Batch?      @relation(fields: [batchId], references: [id])
  leadId                String?
  lead                  Lead?       @relation(fields: [leadId], references: [id])
  studentId             String?
  student               Student?    @relation(fields: [studentId], references: [id])
  metadata              Json?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  @@index([stripeSessionId])
  @@index([customerEmail])
}

model StudentJourney {
  id          String           @id @default(cuid())
  studentId   String
  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  eventType   JourneyEventType
  title       String
  description String?
  metadata    Json?
  createdBy   String?
  createdAt   DateTime         @default(now())
  @@index([studentId, createdAt])
}

model AssessmentQuestion {
  id            String           @id @default(cuid())
  course        CourseType
  category      QuestionCategory @default(THEORY)
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  explanation   String?
  order         Int
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt @default(now())
  createdBy     String?
  @@index([course, category, isActive])
}

model AssessmentAttempt {
  id             String         @id @default(cuid())
  studentId      String
  student        Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course         CourseType
  type           AssessmentType @default(THEORY)
  score          Int
  totalQuestions Int            @default(50)
  passed         Boolean        @default(false)
  answers        Json
  suggestions    Json?
  questionIds    String[]
  attemptNumber  Int            @default(1)
  startedAt      DateTime       @default(now())
  completedAt    DateTime?
  @@index([studentId, type])
}

model ProjectSubmission {
  id            String     @id @default(cuid())
  studentId     String
  student       Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  fileUrl       String?
  fileSize      Int?
  submittedAt   DateTime   @default(now())
  gradedBy      String?
  grade         String?
  score         Int?
  feedback      String?
  status        String     @default("SUBMITTED")
  course        CourseType?
  attemptNumber Int        @default(1)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  @@index([studentId, status])
}

model ResumeReview {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionNumber Int
  scheduledAt   DateTime?
  completedAt   DateTime?
  notes         String?
  reviewerId    String?
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
}

model LinkedInProfile {
  id          String    @id @default(cuid())
  studentId   String    @unique
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  profileUrl  String?
  isVerified  Boolean   @default(false)
  verifiedBy  String?
  verifiedAt  DateTime?
  feedback    String?
  updatedAt   DateTime  @updatedAt
}

model JobApplicationLog {
  id          String      @id @default(cuid())
  studentId   String
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  platform    JobPlatform
  count       Int         @default(1)
  date        DateTime    @default(now())
  notes       String?
  verifiedBy  String?
  @@index([studentId, platform])
}

model WeeklyJobShare {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  weekStarting DateTime
  links        Json
  sharedBy     String
  createdAt    DateTime @default(now())
}

model InterviewSupport {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  company     String
  role        String?
  scheduledAt DateTime?
  completedAt DateTime?
  notes       String?
  outcome     String?
  supportedBy String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SoftwareChecklist {
  id          String   @id @default(cuid())
  studentId   String   @unique
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  items       Json
  allVerified Boolean  @default(false)
  verifiedBy  String?
  verifiedAt  DateTime?
  updatedAt   DateTime @updatedAt
}

model SalesTarget {
  id             String   @id @default(cuid())
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id])
  month          Int
  year           Int
  salesTarget    Int      @default(20)    // Team monthly target: 20 (5 per batch)
  hardTarget     Int      @default(12)    // Hard target: 12 (3 per batch) - must achieve
  leadTarget     Int      @default(50)
  salesAchieved  Int      @default(0)
  leadsGenerated Int      @default(0)
  rolloverFromPrev Int    @default(0)     // Unmet hard target rolled from previous month
  rolloverApplied Boolean @default(false) // Whether rollover has been calculated
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@unique([employeeId, month, year])
}

model SalesIncentive {
  id               String   @id @default(cuid())
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id])
  month            Int
  year             Int
  totalSales       Int      @default(0)
  mandatorySales   Int      @default(5)
  incentivePerSale Float    @default(107)
  totalEarned      Float    @default(0)
  distributed      Float    @default(0)
  distributions    Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@unique([employeeId, month, year])
}

model StudentFeedback {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  type        String   @default("NPS") // NPS, COURSE_FEEDBACK, TESTIMONIAL
  npsScore    Int?     // 0-10
  rating      Int?     // 1-5 stars
  feedback    String?
  testimonial String?  // Public testimonial text
  canPublish  Boolean  @default(false) // Permission to use for marketing
  batchId     String?
  createdAt   DateTime @default(now())
}

model DocumentSignature {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id])
  documentType  String    // TERMS_AND_CONDITIONS, ENROLLMENT_AGREEMENT, PHOTO_CONSENT
  documentUrl   String?   // URL to the document
  signedAt      DateTime?
  signature     String?   // Base64 signature image or typed name
  signatureType String    @default("TYPED") // TYPED, DRAWN
  ipAddress     String?
  verified      Boolean   @default(false)
  verifiedBy    String?
  createdAt     DateTime  @default(now())
}

model WhatsAppTask {
  id              String    @id @default(cuid())
  leadId          String
  lead            Lead      @relation(fields: [leadId], references: [id])
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id])
  message         String    // Pre-composed message
  phoneNumber     String
  status          String    @default("PENDING") // PENDING, SENT, ACKNOWLEDGED
  sentAt          DateTime?
  acknowledgedAt  DateTime?
  acknowledgeNote String?
  createdAt       DateTime  @default(now())
}

model AlumniProfile {
  id              String   @id @default(cuid())
  studentId       String   @unique
  student         Student  @relation(fields: [studentId], references: [id])
  headline        String?
  currentCompany  String?
  currentRole     String?
  location        String?
  linkedInUrl     String?
  isPublic        Boolean  @default(true)
  bio             String?
  skills          String[]
  placedDate      DateTime?
  salary          String?
  willingToMentor Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model JobBoardPost {
  id          String    @id @default(cuid())
  title       String
  company     String
  location    String
  salary      String?
  type        String    @default("FULL_TIME")
  description String
  applyUrl    String?
  postedById  String?
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

model Referral {
  id              String    @id @default(cuid())
  referrerId      String
  referrer        Student   @relation("ReferralsMade", fields: [referrerId], references: [id])
  referredName    String
  referredEmail   String
  referredPhone   String?
  leadId          String?
  status          String    @default("PENDING")
  rewardType      String?
  rewardAmount    Float?
  rewardGiven     Boolean   @default(false)
  rewardGivenAt   DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  userName    String
  userRole    String
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, SEND_EMAIL, etc
  entity      String   // lead, student, batch, session, certificate, etc
  entityId    String?
  entityName  String?  // Human readable name of what was affected
  details     String?  // JSON or text with what changed
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, createdAt])
}
